---
const { contacto, categoriaLabel } = Astro.props;
const waUrl = `https://wa.me/${contacto.whatsapp}?text=${contacto.mensajeWhatsApp}`;
const mailUrl = `mailto:${contacto.email}?subject=${contacto.asuntoEmail}`;
---

<section class="contacto" aria-labelledby="contacto-titulo">
  <div class="contacto__inner reveal">
    <div class="contacto__texto">
      <p class="contacto__eyebrow">¿LISTO PARA POSTULAR?</p>
      <h2 class="contacto__titulo" id="contacto-titulo">
        Habla con tu asesor<br>de {categoriaLabel}.
      </h2>
      <p class="contacto__sub">
        Respuesta en menos de 24 horas con disponibilidad y propuesta.
      </p>
    </div>

    <div class="contacto__botones">
      <a
        href={waUrl}
        class="btn btn--whatsapp"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Contactar asesor de ${categoriaLabel} por WhatsApp`}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WHATSAPP
      </a>
      <a
        href={mailUrl}
        class="btn btn--correo"
        aria-label={`Enviar correo al asesor de ${categoriaLabel}`}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        CORREO
      </a>
      <p class="contacto__email">{contacto.email}</p>
    </div>
  </div>
</section>

<style>
.contacto {
  background: var(--color-morado);
  padding: 80px 48px;
  border-top: 1px solid var(--color-border-on-dark);
}
.contacto__inner {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 60px; align-items: center;
}
.contacto__eyebrow {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px; letter-spacing: 0.22em;
  color: var(--color-verde); margin-bottom: 14px;
}
.contacto__titulo {
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: clamp(28px, 3.5vw, 44px);
  letter-spacing: -0.03em; line-height: 1.1;
  color: white;
}
.contacto__sub {
  font-family: 'Montserrat Alternates', sans-serif;
  font-size: 16px;
  line-height: 1.72;
  color: rgba(255,255,255,0.65);
  margin-top: 18px;
  padding-left: 16px;
  border-left: 2px solid var(--color-verde);
  max-width: 420px;
}
.contacto__botones {
  display: flex; flex-direction: column; gap: 12px;
}
.contacto__email {
  font-family: 'Montserrat Alternates', sans-serif;
  font-size: 13px; color: var(--color-text-on-dark-muted);
  margin-top: 4px;
}

@media (max-width: 980px) {
  .contacto { padding: 64px 24px; }
  .contacto__inner { grid-template-columns: 1fr; gap: 36px; }
}
@media (max-width: 560px) {
  .contacto { padding: 48px 20px; }
}
</style>
