---
const { categoria, chefs } = Astro.props;
const colorActivo = categoria.color === 'multicolor' ? '#B0DA2D' : categoria.color;
const { titulo, verbo, masInfo } = categoria.seccionParticipantes;
---

<section class="chefs" style={`--cat-color:${colorActivo}`} aria-labelledby="chefs-titulo">
  <div class="chefs__head reveal">
    <span class="chefs__slug">/01</span>
    <h2 class="chefs__titulo" id="chefs-titulo">
      {titulo} <em>{verbo}</em>.
    </h2>
  </div>

  <div class="chefs__grid reveal-stagger">
    {chefs.map((c: any) => (
      <article class={`chefs__card${!c.confirmado ? ' chefs__card--pronto' : ''}`}>
        <!-- Foto -->
        <div class="chefs__foto">
          {c.confirmado
            ? (c.imagen
                ? <img src={c.imagen} alt={`Foto de ${c.nombre}`} loading="lazy" />
                : (
                  <div class="chefs__foto-placeholder" aria-hidden="true">
                    <span class="chefs__foto-iniciales">
                      {c.nombre.split(' ').map((w: string) => w[0]).slice(0, 2).join('')}
                    </span>
                  </div>
                )
              )
            : <div class="chefs__foto-misterio" aria-hidden="true"><span>?</span></div>
          }
          {c.confirmado
            ? (c.region && <span class="chefs__region">{c.region}</span>)
            : <span class="chefs__badge-pronto">Próximamente</span>
          }
        </div>

        <!-- Info -->
        <div class="chefs__info">
          {c.confirmado
            ? <>
                <p class="chefs__nombre">{c.nombre}</p>
                <p class="chefs__rol">{c.rol}</p>
                {c.descripcion && <p class="chefs__bio">{c.descripcion}</p>}
              </>
            : <>
                <p class="chefs__nombre chefs__nombre--oculto">▓▓▓▓▓▓▓ ▓▓▓▓▓▓▓</p>
                <p class="chefs__rol chefs__rol--oculto">▓▓▓▓▓▓▓▓▓▓▓</p>
              </>
          }
        </div>
      </article>
    ))}
  </div>

  <p class="chefs__mas reveal">{masInfo}</p>
</section>

<style>
.chefs {
  background: var(--color-morado-deep);
  padding: 100px 48px;
}
.chefs__head {
  display: flex; align-items: baseline; gap: 20px;
  margin-bottom: 64px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--color-border-on-dark);
}
.chefs__slug {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px; letter-spacing: 0.22em;
  color: var(--cat-color); flex-shrink: 0;
}
.chefs__titulo {
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: clamp(40px, 6vw, 72px);
  letter-spacing: -0.03em; line-height: 0.9;
  color: white;
}
.chefs__titulo em {
  font-style: italic; font-weight: 700; color: var(--cat-color);
}

/* Grid */
.chefs__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 40px;
}
.chefs__card {
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid var(--color-border-on-dark);
  background: rgba(255,255,255,0.03);
  display: flex; flex-direction: column;
  transition: transform 0.25s, border-color 0.25s;
}
.chefs__card:hover {
  transform: translateY(-6px);
  border-color: rgba(1,152,172,0.4);
}

/* Foto — proporción 3:4 */
.chefs__foto {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: linear-gradient(145deg, #1a0f2e 0%, #2B1D3E 60%, #0d1a1e 100%);
}
.chefs__foto img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: top center;
  transition: transform 0.4s ease;
}
.chefs__card:hover .chefs__foto img {
  transform: scale(1.04);
}
.chefs__foto-placeholder {
  width: 100%; height: 100%;
  display: grid; place-items: center;
  background: linear-gradient(145deg, #0d1020 0%, #1a1030 50%, #0a1520 100%);
}
.chefs__foto-iniciales {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 8vw, 80px);
  letter-spacing: 0.04em;
  color: rgba(1,152,172,0.35);
  user-select: none;
}

/* Badge de región */
.chefs__region {
  position: absolute; bottom: 12px; left: 12px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 12px; letter-spacing: 0.18em;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  color: var(--cat-color);
  padding: 4px 10px;
  border-radius: 3px;
  border: 1px solid rgba(1,152,172,0.35);
}

/* Bloque de texto */
.chefs__info {
  padding: 18px 18px 22px;
  display: flex; flex-direction: column; gap: 5px;
  flex: 1;
}
.chefs__nombre {
  font-family: 'Manrope', sans-serif;
  font-weight: 700; font-size: 16px;
  color: white; line-height: 1.2;
}
.chefs__rol {
  font-size: 13px; color: rgba(255,255,255,0.5);
}
.chefs__bio {
  font-family: 'Montserrat Alternates', sans-serif;
  font-size: 12px; line-height: 1.55;
  color: rgba(255,255,255,0.45);
  margin-top: 8px;
  padding-top: 10px;
  border-top: 1px solid var(--color-border-on-dark);
}

/* Intriga */
.chefs__card--pronto {
  opacity: 0.75;
  border-color: rgba(255,255,255,0.06);
  pointer-events: none;
}
.chefs__card--pronto:hover {
  transform: none;
  border-color: rgba(255,255,255,0.06);
}
.chefs__foto-misterio {
  width: 100%; height: 100%;
  display: grid; place-items: center;
  background: linear-gradient(145deg, #0a0812 0%, #130d20 50%, #0a0f18 100%);
}
.chefs__foto-misterio span {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(72px, 12vw, 110px);
  color: rgba(255,255,255,0.06);
  user-select: none;
}
.chefs__badge-pronto {
  position: absolute; bottom: 12px; left: 12px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 11px; letter-spacing: 0.22em;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(8px);
  color: rgba(255,255,255,0.35);
  padding: 4px 10px; border-radius: 3px;
  border: 1px solid rgba(255,255,255,0.1);
  text-transform: uppercase;
}
.chefs__nombre--oculto,
.chefs__rol--oculto {
  color: rgba(255,255,255,0.08);
  user-select: none;
}
.chefs__rol--oculto { font-size: 12px; }

.chefs__mas {
  font-family: 'Montserrat Alternates', sans-serif;
  font-size: 13px; color: rgba(255,255,255,0.4);
  letter-spacing: 0.04em;
}

@media (max-width: 980px) {
  .chefs { padding: 72px 24px; }
  .chefs__head { flex-direction: column; align-items: flex-start; gap: 12px; margin-bottom: 40px; }
  .chefs__grid { grid-template-columns: 1fr 1fr; gap: 16px; }
}
@media (max-width: 560px) {
  .chefs { padding: 56px 20px; }
  .chefs__head { margin-bottom: 32px; }
  .chefs__grid { grid-template-columns: 1fr 1fr; gap: 10px; }
  .chefs__nombre { font-size: 15px; }
  .chefs__info { padding: 12px 14px 16px; }
  .chefs__bio { font-size: 11px; }
}
</style>
