    <!-- Evento -->
    <div class="footer__col">
      <h4 class="footer__col-title">EVENTO</h4>
      <a href="/">Inicio</a>
      <a
        href="https://www.ticketmaster.co/event/coffee-flow-colombia-2026"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__link-cta"
      >
        Comprar boletas
        <span aria-hidden="true">→</span>
      </a>
      <div class="footer__divider"></div>
      <span class="footer__dato">
        <span class="footer__dato-label">Sede</span>
        Pabellón Vive Claro
      </span>
      <span class="footer__dato">
        <span class="footer__dato-label">Dirección</span>
        Av. Calle 53 # 66-19
      </span>
    </div>

    <!-- Categorías -->
    <div class="footer__col">
      <h4 class="footer__col-title">CATEGORÍAS</h4>
      {
        CATEGORIAS.map((cat) => {
          const c = cat.color === "multicolor" ? "#B0DA2D" : cat.color;
          return (
            <a href={`/${cat.slug}`} class="footer__cat-link">
              <span class="footer__cat-dot" style={`background:${c}`} />
              {cat.nombreCorto}
            </a>
          );
        })
      }
    </div>

