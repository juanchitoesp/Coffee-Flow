  <a
    href="mailto:infocoffeeflow@gmail.com"
    class="flotante__btn flotante__btn--mail"
    aria-label="Enviar correo a infocoffeeflow@gmail.com"
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2"/>
      <path d="M22 7l-10 7L2 7"/>
    </svg>
    <span class="flotante__tooltip">infocoffeeflow@gmail.com</span>
  </a>
</div>

<style>
.flotante {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 900;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.flotante__btn {
  position: relative;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  flex-shrink: 0;
}
.flotante__btn:hover {
  transform: scale(1.1) translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
}

.flotante__btn svg {
  width: 24px;
  height: 24px;
}

.flotante__btn--wa {
  background: #25D366;
  color: white;
}
.flotante__btn--mail {
  background: #0198AC;
  color: white;
}

/* Tooltip a la izquierda */
.flotante__tooltip {
  position: absolute;
  right: calc(100% + 12px);
  top: 50%;
  transform: translateY(-50%);
  background: rgba(20, 10, 35, 0.92);
  color: white;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px;
  letter-spacing: 0.14em;
  padding: 6px 12px;
  border-radius: 4px;
  white-space: nowrap;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s ease, transform 0.2s ease;
  transform: translateY(-50%) translateX(6px);
}
.flotante__tooltip::after {
  content: '';
  position: absolute;
  left: 100%;
  top: 50%;
  transform: translateY(-50%);
  border: 5px solid transparent;
  border-left-color: rgba(20, 10, 35, 0.92);
}
.flotante__btn:hover .flotante__tooltip {
  opacity: 1;
  transform: translateY(-50%) translateX(0);
}

@media (max-width: 560px) {
  .flotante {
    bottom: 20px;
    right: 16px;
  }
  .flotante__btn {
    width: 46px;
    height: 46px;
  }
  .flotante__btn svg {
    width: 21px;
    height: 21px;
  }
  .flotante__tooltip {
    display: none;
  }
}
</style>
