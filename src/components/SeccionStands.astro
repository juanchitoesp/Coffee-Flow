---
import StandCard from './StandCard.astro';

const { categoria } = Astro.props;
const colorActivo = categoria.color === 'multicolor' ? '#B0DA2D' : categoria.color;
const { tituloPre, palabraColor, stands } = categoria.seccionStands;
const numero = categoria.numero ?? '02';
const paraDesc = categoria.paraEmpresas?.descripcion ?? 'Elige el formato que mejor represente tu marca.';
---

<section class="stands" style={`--cat-color:${colorActivo}`} aria-labelledby="stands-titulo">
  <div class="stands__glow" aria-hidden="true"></div>

  <header class="stands__header reveal">
    <span class="stands__slug">/{numero}</span>
    <h2 class="stands__titulo" id="stands-titulo">
      {tituloPre} <em>{palabraColor}</em>.
    </h2>
    <p class="stands__sub">{paraDesc}</p>
  </header>

  <div class="stands__grid reveal-stagger">
    {stands.map((stand: any) => (
      <StandCard stand={stand} />
    ))}
  </div>

  <div class="stands__personalizado reveal">
    <span class="stands__personalizado-icono" aria-hidden="true">✦</span>
    <p>
      <strong>Plan personalizado disponible</strong> — Diseña un espacio a tu medida.
      <span class="stands__personalizado-precio">$1.500.000 / m² adicional</span>
    </p>
    <a
      href="https://wa.me/573202751029?text=Hola%20Alejandra%2C%20quiero%20información%20sobre%20un%20plan%20personalizado%20en%20Coffee%20Flow%20Colombia%202026"
      target="_blank" rel="noopener noreferrer"
      class="stands__personalizado-cta"
      aria-label="Consultar plan personalizado por WhatsApp"
    >Consultar →</a>
  </div>
</section>

<style>
.stands {
  background: var(--color-morado-deep);
  padding: 52px 48px 56px;
  position: relative; overflow: hidden;
}
.stands__glow {
  position: absolute; top: -140px; right: -140px;
  width: 520px; height: 520px; border-radius: 50%;
  background: var(--cat-color); opacity: 0.05;
  pointer-events: none;
}

/* Header */
.stands__header {
  display: flex; flex-direction: column;
  padding-bottom: 22px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  margin-bottom: 28px;
  position: relative; z-index: 1;
}
.stands__slug {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 12px; letter-spacing: 0.26em;
  color: var(--cat-color);
  margin-bottom: 10px;
}
.stands__titulo {
  font-family: 'Manrope', sans-serif;
  font-weight: 800;
  font-size: clamp(36px, 5vw, 62px);
  letter-spacing: -0.03em; line-height: 0.9;
  color: white;
}
.stands__titulo em {
  font-style: italic; color: var(--cat-color);
}
.stands__sub {
  font-family: 'Montserrat Alternates', sans-serif;
  font-size: 15px; line-height: 1.68;
  color: rgba(255,255,255,0.5);
  max-width: 560px;
  margin-top: 16px;
  padding-left: 14px;
  border-left: 2px solid var(--cat-color);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Grid */
.stands__grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 16px; position: relative; z-index: 1;
}

/* Personalizado */
.stands__personalizado {
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  margin-top: 20px;
  padding: 18px 22px;
  border: 1px dashed rgba(255,255,255,0.10);
  border-radius: 8px;
  background: rgba(255,255,255,0.02);
  position: relative; z-index: 1;
}
.stands__personalizado-icono {
  font-size: 16px; color: var(--cat-color); flex-shrink: 0;
}
.stands__personalizado p {
  font-family: 'Montserrat Alternates', sans-serif;
  font-size: 13px; color: rgba(255,255,255,0.45); line-height: 1.5; flex: 1;
}
.stands__personalizado strong {
  color: rgba(255,255,255,0.8); font-weight: 600;
}
.stands__personalizado-precio {
  display: inline-block;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 14px; letter-spacing: 0.12em;
  color: var(--cat-color);
  margin-left: 6px;
}
.stands__personalizado-cta {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 13px; letter-spacing: 0.18em;
  color: white;
  padding: 9px 20px;
  border: 1.5px solid rgba(255,255,255,0.18);
  border-radius: 4px;
  white-space: nowrap;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
  flex-shrink: 0;
}
.stands__personalizado-cta:hover {
  background: var(--cat-color);
  border-color: var(--cat-color);
  color: #2B1D3E;
}

@media (max-width: 980px) {
  .stands { padding: 44px 24px 48px; }
  .stands__grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
  .stands__grid :global(.stand-card--xl) { order: -1; }
  .stands__sub { max-width: none; }
}
@media (max-width: 560px) {
  .stands { padding: 36px 20px 40px; }
}
</style>
