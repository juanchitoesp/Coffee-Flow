---
import Layout from "../layouts/Layout.astro";
import { CATEGORIAS } from "../data/categorias.js";
import Countdown from "../components/Countdown.astro";

const TEXTO_CLARO = ["#FFE700", "#B0DA2D"];

const DESTACADOS = [
  {
    nombre: "Tatiana de los Ríos",
    rol: "Conductora del Festival",
    detalle: "Host Oficial",
    badge: "HOST",
    badgeColor: "#FFE700",
    textColor: "#2B1D3E",
    imagen: "/assets/iconos/tati.jpg",
    link: "/musica",
    confirmado: true,
    esHost: true,
  },
  {
    nombre: "Sanalejo",
    rol: "Banda",
    detalle: "Pop Rock",
    badge: "MÚSICA",
    badgeColor: "#0198AC",
    textColor: "white",
    imagen: "assets/iconos/sanalejo.jpg",
    link: "/musica",
    confirmado: true,
  },
  {
    nombre: "Gusi",
    rol: "Cantante y compositor",
    detalle: "Pop Latino",
    badge: "MÚSICA",
    badgeColor: "#0198AC",
    textColor: "white",
    imagen: "assets/iconos/Gusi.jpg",
    link: "/musica",
    confirmado: true,
  },
  {
    nombre: "Natalia París",
    rol: "DJ · Tech House",
    detalle: "Internacional",
    badge: "MÚSICA",
    badgeColor: "#0198AC",
    textColor: "white",
    imagen: "assets/iconos/nataparis.webp",
    link: "/musica",
    confirmado: true,
  },
  {
    nombre: "Leonor Espinosa",
    rol: "Chef · Restaurante Leo",
    detalle: "Bogotá",
    badge: "GASTRONOMÍA",
    badgeColor: "#FFE700",
    textColor: "#2B1D3E",
    imagen: "/assets/chefs/leonor-espinosa.jpg",
    link: "/gastronomia",
    confirmado: false,
  },
  {
    nombre: "Pergamino",
    rol: "Tostadora de especialidad",
    detalle: "Medellín",
    badge: "CAFÉ",
    badgeColor: "#B0DA2D",
    textColor: "#2B1D3E",
    imagen: "/assets/tostadores/pergamino.jpg",
    link: "/cafe",
    confirmado: false,
  },
  {
    nombre: "Café San Alberto",
    rol: "Finca & Tostadora",
    detalle: "Huila",
    badge: "CAFÉ",
    badgeColor: "#B0DA2D",
    textColor: "#2B1D3E",
    imagen: "/assets/tostadores/san-alberto.jpg",
    link: "/cafe",
    confirmado: false,
  },
];

const LINEUP_HERO = [
  DESTACADOS.find((p) => p.nombre === "Tatiana de los Ríos"),
  DESTACADOS.find((p) => p.nombre === "Gusi"),
  DESTACADOS.find((p) => p.nombre === "Sanalejo"),
  DESTACADOS.find((p) => p.nombre === "Natalia París"),
].filter(Boolean);

const POR_QUE = [
  {
    titulo: "Alcance Masivo",
    descripcion: "+50.000 asistentes y +200 marcas expositoras.",
  },
  {
    titulo: "Público Calificado",
    descripcion:
      "Compradores nacionales e internacionales, distribuidores y consumidor final premium.",
  },
  {
    titulo: "Gran Impacto Mediático",
    descripcion: "Cobertura de medios nacionales e influencers.",
  },
  {
    titulo: "Entretenimiento de Alto Nivel",
    descripcion:
      "Artistas nacionales e internacionales. Conducción: Don Fulanito (José Rafael Fuente).",
  },
  {
    titulo: "Innovación",
    descripcion:
      "Sede del Primer Campeonato Nacional de Cafeterías de Especialidad.",
  },
];

const EXPERIENCIA_INCLUYE = [
  "Zona de exhibición de marcas de café de especialidad",
  "Primer Campeonato Nacional de Cafeterías de especialidad",
  "Experiencias sensoriales y gastronómicas",
  "Exhibición de maquinaria e industria",
  "Conciertos y programación cultural en vivo",
];

const PQ_COLORS = ["#FFE700", "#0198AC", "#B0DA2D", "#DE1551", "#B0DA2D"];

const schema = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: "Coffee Flow Colombia 2026",
  description:
    "El primer festival de café, cultura, gastronomía e innovación de gran formato en Latinoamérica. Tres días de conciertos, experiencias sensoriales, campeonato nacional de cafeterías y más de 200 marcas expositoras.",
  startDate: "2026-07-31T10:00:00-05:00",
  endDate: "2026-08-02T22:00:00-05:00",
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  url: "https://coffeeflow.info",
  image: ["https://coffeeflow.info/og-image.jpg"],
  location: {
    "@type": "Place",
    name: "Pabellón Vive Claro",
    address: {
      "@type": "PostalAddress",
      streetAddress: "Cra. 40 #22C-67",
      addressLocality: "Bogotá",
      addressRegion: "Cundinamarca",
      postalCode: "111311",
      addressCountry: "CO",
    },
  },
  organizer: {
    "@type": "Organization",
    name: "Inversiones KJNV S.A.S. · Café MAJUKA",
    url: "https://coffeeflow.info",
  },
  performer: [
    { "@type": "MusicGroup", name: "Sanalejo" },
    { "@type": "Person", name: "Gusi" },
  ],
  offers: {
    "@type": "Offer",
    name: "Entrada General",
    availability: "https://schema.org/PreOrder",
    url: "https://coffeeflow.info#boletas",
    validFrom: "2026-06-01T00:00:00-05:00",
  },
  keywords:
    "festival café Colombia, café de especialidad, gastronomía Bogotá, conciertos Bogotá 2026, Coffee Flow",
};
---

<Layout
  title="Coffee Flow Colombia 2026 · Festival de Café, Cultura y Gastronomía en Bogotá"
  description="El primer festival de café, cultura, gastronomía e innovación de gran formato en Latinoamérica. 31 jul – 2 ago 2026 · Pabellón Vive Claro · Bogotá, Colombia."
  canonical="https://coffeeflow.info"
  keywords="Coffee Flow Colombia 2026, festival café Bogotá, festival gastronómico Colombia, conciertos Bogotá julio 2026, café de especialidad Colombia, Vive Claro Bogotá, festival cultural café"
  schema={schema}
>
  <!-- ============ HERO ============ -->
  <section class="hero" aria-labelledby="hero-titulo">
    <!-- Columna izquierda -->
    <div class="hero__left">
      <!-- Decoración: círculos de fondo -->
      <div class="hero__deco hero__deco--1" aria-hidden="true"></div>
      <div class="hero__deco hero__deco--2" aria-hidden="true"></div>

      <div class="hero__content">
        <p class="hero__eyebrow">
          <span class="hero__dot" aria-hidden="true"></span>
          DEL 31 DE JULIO AL 2 DE AGOSTO · BOGOTÁ
        </p>

        <!-- Patrocinador oficial -->
        <div class="hero__sponsor">
          <span class="hero__sponsor-label">PATROCINADOR OFICIAL</span>
          <img
            src="/assets/iconos/viveclaro-logo.svg"
            alt="Vive Claro – Patrocinador Oficial"
            class="hero__sponsor-logo"
            loading="eager"
          />
        </div>

        <div class="hero__titulo-row">
          <img
            src="/assets/iconos/mascotaa.svg"
            alt=""
            class="hero__mascota-mobile"
            aria-hidden="true"
            loading="eager"
          />
          <h1 class="hero__titulo" id="hero-titulo">
            <span class="hero__titulo-line hero__titulo-line--1">COFFEE</span>
            <span class="hero__titulo-line hero__titulo-line--2">
              <span style="color:#B0DA2D">F</span><span style="color:#FFE700"
                >L</span
              ><span style="color:#DE1551">O</span><span style="color:#0198AC"
                >W</span
              >
            </span>
            <span class="hero__titulo-line hero__titulo-line--3">COLOMBIA</span>
          </h1>
        </div>

        <!-- Carrusel de artistas confirmados -->
        <div class="hero__lineup" id="heroLineup" role="region" aria-label="Artistas confirmados en escena">
          <div class="hero__lineup-header">
            <p class="hero__lineup-label">
              <span class="hero__lineup-pulse" aria-hidden="true"></span>
              ARTISTAS CONFIRMADOS
            </p>
            <span class="hero__lineup-counter" id="lineupCounter">01 / 03</span>
          </div>
          <div class="hero__lineup-stage">
            {
              LINEUP_HERO.map((p, i) => (
                <a
                  href={p.link}
                  class={`hero__lineup-card${i === 0 ? " hero__lineup-card--active" : ""}`}
                  data-li={i}
                >
                  <div class="hero__lineup-foto">
                    <img src={p.imagen} alt={`Foto de ${p.nombre}`} loading="eager" />
                  </div>
                  <div class="hero__lineup-info">
                    <strong class="hero__lineup-nombre">{p.nombre}</strong>
                    <span class="hero__lineup-rol">{p.rol}</span>
                    <span class="hero__lineup-genero">{p.detalle}</span>
                  </div>
                  <span class="hero__lineup-arr" aria-hidden="true">→</span>
                </a>
              ))
            }
          </div>
          <div class="hero__lineup-footer">
            <div class="hero__lineup-progress" aria-hidden="true">
              <div class="hero__lineup-bar" id="lineupBar"></div>
            </div>
            <div class="hero__lineup-thumbs" aria-label="Navegar artistas">
              {
                LINEUP_HERO.map((p, i) => (
                  <button
                    class={`hero__lineup-thumb${i === 0 ? " hero__lineup-thumb--active" : ""}`}
                    data-dot={i}
                    tabindex="-1"
                    aria-label={`Ver ${p.nombre}`}
                  >
                    <img src={p.imagen} alt={p.nombre} loading="eager" />
                  </button>
                ))
              }
            </div>
          </div>
        </div>

        <p class="hero__subtitulo">
          El primer festival de café, cultura,<br />gastronomía e innovación<br
          />
          <em>de gran formato en Latinoamérica.</em>
        </p>

        <div class="hero__acciones">
          <div class="hero__boletas-pronto" role="status">
            <span class="hero__bp-dot" aria-hidden="true"></span>
            <div>
              <strong class="hero__bp-titulo">BOLETAS PRÓXIMAMENTE</strong>
              <span class="hero__bp-sub"
                >Venta abre pronto en Ticketmaster · Precios próximamente</span
              >
            </div>
            <a
              href="#boletas"
              class="hero__bp-link"
              aria-label="Ver precios de boletas">↓</a
            >
          </div>
          <a href="/gastronomia" class="btn btn--outline">QUIERO PARTICIPAR</a>
        </div>

        <div class="hero__early-bird">
          <span class="hero__eb-pulse" aria-hidden="true"></span>
          <div>
            <strong class="hero__eb-label">PREVENTA · CUPOS LIMITADOS</strong>
            <span class="hero__eb-sub"
              >Las primeras 20 marcas confirmadas reciben mayor visibilidad
              digital + prioridad en ubicación</span
            >
          </div>
        </div>

        <div class="hero__datos">
          <div class="hero__dato">
            <span class="hero__dato-val">50K</span>
            <span class="hero__dato-label">ASISTENTES</span>
          </div>
          <div class="hero__dato">
            <span class="hero__dato-val">3</span>
            <span class="hero__dato-label">DÍAS</span>
          </div>
          <div class="hero__dato">
            <span class="hero__dato-val">6</span>
            <span class="hero__dato-label">REGIONES</span>
          </div>
          <div class="hero__dato">
            <span class="hero__dato-val">1</span>
            <span class="hero__dato-label">ESCENARIO</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Columna derecha: bloques de categoría -->
    <div class="hero__right" aria-label="Categorías del festival">
      <!-- Emblema mascota -->
      <div class="hero__emblema" aria-hidden="true"></div>

      {
        CATEGORIAS.map((cat) => {
          const c = cat.color === "multicolor" ? "#B0DA2D" : cat.color;
          const textColor = TEXTO_CLARO.includes(c) ? "#2B1D3E" : "white";
          return (
            <a
              href={`/${cat.slug}`}
              class="hero__bloque"
              style={`--bc:${c}; --tc:${textColor};`}
              aria-label={`Ver ${cat.nombreCorto}`}
            >
              <span class="hero__bloque-num">{cat.numero}</span>
              <span
                class="hero__bloque-icono"
                set:html={cat.iconosvgwhite}
                aria-hidden="true"
              />
              <div class="hero__bloque-texto">
                <span class="hero__bloque-nombre">{cat.nombre}</span>
                <span class="hero__bloque-tag">{cat.palabraEmocional}</span>
              </div>
              <span class="hero__bloque-flecha" aria-hidden="true">
                →
              </span>
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- ============ CUENTA REGRESIVA ============ -->
  <Countdown />

  <!-- ============ NATALIA PARÍS · ARTISTA DESTACADA ============ -->
  <section class="np-destaque" aria-labelledby="np-titulo">
    <div class="np-destaque__inner">
      <div class="np-destaque__content reveal">
        <p class="np-destaque__eyebrow">
          <span class="np-destaque__dot" aria-hidden="true"></span>
          ARTISTA INTERNACIONAL CONFIRMADA
        </p>
        <h2 class="np-destaque__nombre" id="np-titulo">
          <span class="np-destaque__n1">NATALIA</span>
          <span class="np-destaque__n2">PARÍS</span>
        </h2>
        <div class="np-destaque__genero">
          <span>DJ</span>
          <span aria-hidden="true">·</span>
          <span>TECH HOUSE</span>
          <span aria-hidden="true">·</span>
          <span>ELECTRÓNICA</span>
        </div>
        <a href="/musica" class="np-destaque__cta">Ver lineup completo →</a>
      </div>
      <div class="np-destaque__foto-wrap">
        <div class="np-destaque__glow" aria-hidden="true"></div>
        <img
          src="assets/iconos/nataparis.webp"
          alt="Natalia París, DJ Tech House internacional"
          class="np-destaque__foto"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- ============ PROTAGONISTAS ============ -->
  <section class="protas" aria-labelledby="protas-titulo">
    <div class="protas__head reveal">
      <div>
        <h2 class="protas__titulo" id="protas-titulo">
          Los <em>protagonistas</em>.
        </h2>
      </div>
      <div class="protas__links">
        <a href="/musica" class="protas__link" style="--lc:#0198AC"
          >Ver lineup →</a
        >
        <a href="/gastronomia" class="protas__link" style="--lc:#FFE700"
          >Ver chefs →</a
        >
        <a href="/cafe" class="protas__link" style="--lc:#B0DA2D">Ver café →</a>
      </div>
    </div>

    <div class="protas__grid reveal-stagger">
      {
        DESTACADOS.map((p) => (
          <a
            href={p.confirmado ? p.link : undefined}
            class={`prota__card${!p.confirmado ? " prota__card--pronto" : ""}${p.esHost ? " prota__card--host" : ""}`}
            style={`--bc:${p.badgeColor}; --tc:${p.textColor};`}
          >
            <div class="prota__foto">
              {p.confirmado ? (
                p.imagen ? (
                  <img
                    src={p.imagen}
                    alt={`Foto de ${p.nombre}`}
                    loading="lazy"
                  />
                ) : (
                  <div class="prota__foto-placeholder" aria-hidden="true">
                    <span class="prota__foto-iniciales">
                      {p.nombre
                        .split(" ")
                        .map((w: string) => w[0])
                        .slice(0, 2)
                        .join("")}
                    </span>
                  </div>
                )
              ) : (
                <div class="prota__foto-misterio" aria-hidden="true">
                  <span>?</span>
                </div>
              )}
              {p.confirmado ? (
                <>
                  <span class="prota__badge">{p.badge}</span>
                  <div class="prota__overlay" aria-hidden="true">
                    <span class="prota__overlay-cta">Ver más →</span>
                  </div>
                </>
              ) : (
                <span class="prota__badge-pronto">Próximamente</span>
              )}
            </div>
            <div class="prota__info">
              {p.confirmado ? (
                <>
                  <p class="prota__nombre">{p.nombre}</p>
                  <p class="prota__rol">{p.rol}</p>
                  <p class="prota__detalle">{p.detalle}</p>
                </>
              ) : (
                <>
                  <p class="prota__nombre prota__nombre--oculto">
                    ▓▓▓▓▓▓ ▓▓▓▓▓
                  </p>
                  <p class="prota__rol prota__rol--oculto">▓▓▓▓▓▓▓▓▓▓</p>
                </>
              )}
            </div>
          </a>
        ))
      }
    </div>

    <p class="protas__aviso reveal">
      + Más artistas, chefs y expositores por confirmar · Lineup completo
      próximamente
    </p>
  </section>

  <!-- ============ MARQUEE ============ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__inner">
      {
        [...Array(2)].map(() => (
          <>
            <>
              <span>50,000 ASISTENTES</span>
              <span class="marquee__sep">·</span>
            </>
            <>
              <span>3 DÍAS</span>
              <span class="marquee__sep">·</span>
            </>
            <>
              <span>5 EXPERIENCIAS</span>
              <span class="marquee__sep">·</span>
            </>
            <>
              <span>VIVE CLARO</span>
              <span class="marquee__sep">·</span>
            </>
            <>
              <span>BOGOTÁ, COLOMBIA</span>
              <span class="marquee__sep">·</span>
            </>
            <>
              <span>PRIMER FESTIVAL DE GRAN FORMATO</span>
              <span class="marquee__sep">·</span>
            </>
          </>
        ))
      }
    </div>
  </div>

  <!-- ============ BOLETAS ============ -->
  <section class="boletas" id="boletas" aria-labelledby="boletas-titulo">
    <div class="boletas__head reveal">
      <p class="boletas__eyebrow">BOLETAS</p>
      <h2 class="boletas__titulo" id="boletas-titulo">Precios próximamente</h2>
      <div class="boletas__pronto-banner" role="status">
        <span class="boletas__pronto-dot" aria-hidden="true"></span>
        <span
          >Venta de boletas abre próximamente en <strong
            >Ticketmaster Colombia</strong
          ></span
        >
      </div>
    </div>

    <div class="boletas__grid reveal-stagger">
      <!-- Días 1 y 2 -->
      <div class="boleta__card">
        <div class="boleta__pills">
          <span class="boleta__pill">BOLETA POR DÍA</span>
          <span class="boleta__pill boleta__pill--mismo">MISMO PRECIO</span>
        </div>
        <div class="boleta__fechas">
          <span class="boleta__fecha">31 Jul</span>
          <span class="boleta__fecha-sep">+</span>
          <span class="boleta__fecha">1 Ago</span>
        </div>
        <div class="boleta__filas">
          <div class="boleta__fila">
            <span class="boleta__tipo">General</span>
            <span class="boleta__precio boleta__precio--pronto">PRÓXIMAMENTE</span>
          </div>
          <div class="boleta__fila boleta__fila--vip">
            <span class="boleta__tipo">VIP <span class="boleta__vip-badge">VIP</span></span>
            <span class="boleta__precio boleta__precio--pronto">PRÓXIMAMENTE</span>
          </div>
          <div class="boleta__fila boleta__fila--gratis">
            <span class="boleta__tipo">Niños</span>
            <span class="boleta__precio boleta__precio--gratis">GRATIS</span>
          </div>
        </div>
        <div class="boleta__cta-wrap">
          <div class="boleta__cta-pronto" aria-disabled="true">
            <span>COMPRAR</span>
            <span class="boleta__cta-tag">PRÓXIMAMENTE</span>
          </div>
        </div>
      </div>

      <!-- Día 3 -->
      <div class="boleta__card boleta__card--dia3">
        <div class="boleta__pills">
          <span class="boleta__pill">BOLETA POR DÍA</span>
          <span class="boleta__pill boleta__pill--cierre">CIERRE DEL FESTIVAL</span>
        </div>
        <div class="boleta__fechas">
          <span class="boleta__fecha">2 Ago</span>
        </div>
        <div class="boleta__filas">
          <div class="boleta__fila">
            <span class="boleta__tipo">General</span>
            <span class="boleta__precio boleta__precio--pronto">PRÓXIMAMENTE</span>
          </div>
          <div class="boleta__fila boleta__fila--vip">
            <span class="boleta__tipo">VIP <span class="boleta__vip-badge">VIP</span></span>
            <span class="boleta__precio boleta__precio--pronto">PRÓXIMAMENTE</span>
          </div>
          <div class="boleta__fila boleta__fila--gratis">
            <span class="boleta__tipo">Niños</span>
            <span class="boleta__precio boleta__precio--gratis">GRATIS</span>
          </div>
        </div>
        <div class="boleta__cta-wrap">
          <div class="boleta__cta-pronto" aria-disabled="true">
            <span>COMPRAR</span>
            <span class="boleta__cta-tag">PRÓXIMAMENTE</span>
          </div>
        </div>
      </div>
    </div>

    <p class="boletas__nota reveal">
      Menores de 12 años con acceso gratuito acompañados de un adulto · Los precios se anunciarán próximamente
    </p>
  </section>

  <!-- ============ POR QUÉ PARTICIPAR ============ -->
  <section class="porque" aria-labelledby="porque-titulo">
    <div class="porque__head reveal">
      <p class="porque__eyebrow">RAZONES PARA ESTAR AQUÍ</p>
      <h2 class="porque__titulo" id="porque-titulo">
        ¿Por qué <em>participar</em>?
      </h2>
    </div>
    <div class="porque__grid reveal-stagger">
      {
        POR_QUE.map((razon, i) => (
          <div class="porque__card" style={`--pq-color:${PQ_COLORS[i]}`}>
            <span class="porque__num">{"0" + (i + 1)}</span>
            <strong class="porque__titulo-card">{razon.titulo}</strong>
            <p class="porque__desc">{razon.descripcion}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ CINCO EXPERIENCIAS ============ -->
  <section class="experiencias" aria-labelledby="exp-titulo">
    <div class="experiencias__head reveal">
      <div>
        <h2 class="experiencias__titulo" id="exp-titulo">
          Cinco mundos.<br /><em>Un solo festival.</em>
        </h2>
      </div>
      <p class="experiencias__sub">
