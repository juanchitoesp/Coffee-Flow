    line-height: 0.9;
    color: white;
  }
  .protas__titulo em {
    font-style: italic;
    color: #de1551;
  }
  .protas__links {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-shrink: 0;
  }
  .protas__link {
    font-family: "Bebas Neue", sans-serif;
    font-size: 14px;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
    border-bottom: 1px solid transparent;
    transition:
      color 0.2s,
      border-color 0.2s;
  }
  .protas__link:hover {
    color: var(--lc);
    border-color: var(--lc);
  }

  /* Grid de 6 tarjetas */
  .protas__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 14px;
    margin-bottom: 32px;
  }

  .prota__card {
    display: flex;
    flex-direction: column;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border-on-dark);
    background: rgba(255, 255, 255, 0.02);
    transition:
      transform 0.3s,
      border-color 0.3s;
  }
  .prota__card:hover {
    transform: translateY(-6px);
    border-color: var(--bc);
  }

  /* Foto — 3:4 con overlay hover */
  .prota__foto {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: linear-gradient(145deg, #1a0f2e 0%, #2b1d3e 60%, #0d1a1e 100%);
  }
  .prota__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.45s ease;
    display: block;
  }
  .prota__card:hover .prota__foto img {
    transform: scale(1.06);
  }

  .prota__foto-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: linear-gradient(145deg, #0d1020 0%, #1a1030 50%, #0a1520 100%);
  }
  .prota__foto-iniciales {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(32px, 5vw, 56px);
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.12);
    user-select: none;
  }

  /* Badge de categoría */
  .prota__badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
    font-family: "Bebas Neue", sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    background: var(--bc);
    color: var(--tc);
    padding: 3px 9px;
    border-radius: 3px;
  }

  /* Overlay al hover */
  .prota__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .prota__card:hover .prota__overlay {
    opacity: 1;
  }
  .prota__overlay-cta {
    font-family: "Bebas Neue", sans-serif;
    font-size: 16px;
    letter-spacing: 0.18em;
    color: white;
    transform: translateY(6px);
    transition: transform 0.3s;
  }
  .prota__card:hover .prota__overlay-cta {
    transform: translateY(0);
  }

  /* Info debajo */
  .prota__info {
    padding: 14px 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .prota__nombre {
    font-family: "Manrope", sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: white;
    line-height: 1.2;
  }
  .prota__rol {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.3;
  }
  .prota__detalle {
    font-family: "Bebas Neue", sans-serif;
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--bc);
    margin-top: 2px;
  }

  /* Intriga */
  .prota__card--host {
    border-color: rgba(255, 231, 0, 0.45);
    box-shadow: 0 0 32px rgba(255, 231, 0, 0.08), inset 0 0 0 1px rgba(255,231,0,0.08);
  }
  .prota__card--host:hover {
    border-color: rgba(255, 231, 0, 0.7);
    box-shadow: 0 12px 48px rgba(255, 231, 0, 0.14);
  }
  .prota__card--pronto {
    opacity: 0.75;
    border-color: rgba(255, 255, 255, 0.06);
    pointer-events: none;
  }
  .prota__card--pronto:hover {
    transform: none;
    border-color: rgba(255, 255, 255, 0.06);
  }
  .prota__foto-misterio {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: linear-gradient(145deg, #0a0812 0%, #130d20 50%, #0a0f18 100%);
  }
  .prota__foto-misterio span {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(60px, 10vw, 100px);
    color: rgba(255, 255, 255, 0.06);
    user-select: none;
  }
  .prota__badge-pronto {
    position: absolute;
    bottom: 10px;
    left: 10px;
    font-family: "Bebas Neue", sans-serif;
    font-size: 11px;
    letter-spacing: 0.22em;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    color: rgba(255, 255, 255, 0.35);
    padding: 3px 9px;
    border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-transform: uppercase;
  }
  .prota__nombre--oculto,
  .prota__rol--oculto {
    color: rgba(255, 255, 255, 0.08);
    user-select: none;
  }
  .prota__rol--oculto {
    font-size: 11px;
  }

  .protas__aviso {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 13px;
    font-style: italic;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* ============================================================
   B2B
   ============================================================ */
  .b2b {
    background: #faf9f4;
    padding: 100px 48px;
    position: relative;
    overflow: hidden;
  }
  .b2b::before {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: #ffe700;
    opacity: 0.2;
    pointer-events: none;
  }
  .b2b__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .b2b__eyebrow {
    font-family: "Bebas Neue", sans-serif;
    font-size: 13px;
    letter-spacing: 0.22em;
    color: #0198ac;
    margin-bottom: 16px;
  }
  .b2b__titulo {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(34px, 4vw, 56px);
    letter-spacing: -0.03em;
    line-height: 0.92;
    color: #2b1d3e;
    margin-bottom: 20px;
  }
  .b2b__titulo em {
    font-style: italic;
    color: #0198ac;
  }
  .b2b__desc {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 16px;
    line-height: 1.72;
    color: rgba(43, 29, 62, 0.62);
    margin-bottom: 32px;
    padding-left: 16px;
    border-left: 2px solid #0198ac;
  }
  .b2b__acciones {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .b2b__link {
    font-family: "Bebas Neue", sans-serif;
    font-size: 15px;
    letter-spacing: 0.16em;
    color: #2b1d3e;
    padding: 10px 22px;
    border: 1.5px solid rgba(43, 29, 62, 0.2);
    border-radius: 4px;
    transition:
      background 0.25s,
      border-color 0.25s,
      color 0.25s;
  }
  .b2b__link:hover {
    background: var(--lc);
    border-color: var(--lc);
    color: #2b1d3e;
  }
  .b2b__metricas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .b2b__metrica {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 24px 20px;
    border: 1.5px solid rgba(43, 29, 62, 0.1);
    border-radius: 6px;
    background: white;
  }
  .b2b__metrica-val {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(28px, 2.8vw, 40px);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .b2b__metrica-label {
    font-family: "Manrope", sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #2b1d3e;
    line-height: 1.2;
  }
  .b2b__metrica-sub {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 12px;
    color: rgba(43, 29, 62, 0.45);
    line-height: 1.4;
  }

  /* ============================================================
   DETRÁS
   ============================================================ */
  .detras {
    background: var(--color-morado);
    padding: 100px 48px;
    border-top: 1px solid var(--color-border-on-dark);
  }
  .detras__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
  }
  .detras__eyebrow {
    font-family: "Bebas Neue", sans-serif;
    font-size: 13px;
    letter-spacing: 0.22em;
    color: var(--color-magenta);
    margin-bottom: 16px;
  }
  .detras__titulo {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(36px, 4.5vw, 60px);
    letter-spacing: -0.03em;
    line-height: 0.9;
    color: white;
    margin-bottom: 32px;
  }
  .detras__titulo em {
    font-style: italic;
    color: var(--color-amarillo);
  }
  .detras__quote {
    border-left: 2px solid var(--color-magenta);
    padding-left: 20px;
    margin-bottom: 28px;
  }
  .detras__quote p {
    font-family: "Montserrat Alternates", sans-serif;
    font-style: italic;
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.78);
    margin-bottom: 16px;
    padding-left: 0;
  }
  .detras__quote strong {
    font-size: 14px;
    color: white;
    display: block;
  }
  .detras__quote span {
    font-size: 12px;
    color: var(--color-text-on-dark-muted);
  }
  .detras__cta {
    font-family: "Bebas Neue", sans-serif;
    font-size: 16px;
    letter-spacing: 0.14em;
    color: var(--color-magenta);
    transition: letter-spacing 0.2s;
  }
  .detras__cta:hover {
    letter-spacing: 0.2em;
  }
  .detras__pilares {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .detras__pilar {
    padding: 22px 18px;
    border: 1px solid var(--color-border-on-dark);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .detras__pilar-num {
    font-family: "Bebas Neue", sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--color-magenta);
  }
  .detras__pilar strong {
    font-family: "Manrope", sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: white;
  }
  .detras__pilar p {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 13px;
    color: var(--color-text-on-dark-muted);
    line-height: 1.6;
  }

  /* ============================================================
   COMUNIDAD
   ============================================================ */
  .comunidad {
    background: var(--color-morado-deep);
    padding: 100px 48px;
    border-top: 1px solid var(--color-border-on-dark);
  }
  .comunidad__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }
  .comunidad__eyebrow {
    font-family: "Bebas Neue", sans-serif;
    font-size: 13px;
    letter-spacing: 0.22em;
    color: #b0da2d;
    margin-bottom: 16px;
  }
  .comunidad__titulo {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(36px, 4.5vw, 60px);
    letter-spacing: -0.03em;
    line-height: 0.9;
    color: white;
    margin-bottom: 20px;
  }
  .comunidad__titulo em {
    font-style: italic;
    color: #b0da2d;
  }
  .comunidad__desc {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 16px;
    line-height: 1.72;
    color: rgba(255, 255, 255, 0.68);
    margin-bottom: 28px;
    padding-left: 16px;
    border-left: 2px solid #b0da2d;
  }
  .comunidad__metricas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .comunidad__metrica {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 22px 18px;
    border: 1px solid var(--color-border-on-dark);
    border-radius: 6px;
  }
  .comunidad__val {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(38px, 4vw, 54px);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .comunidad__metrica span:last-child {
    font-family: "Bebas Neue", sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* ============================================================
   EARLY-BIRD BADGE (hero)
   ============================================================ */
  .hero__early-bird {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(222, 21, 81, 0.1);
    border: 1px solid rgba(222, 21, 81, 0.28);
    border-radius: 6px;
    padding: 12px 18px;
    margin-bottom: 32px;
    max-width: 540px;
  }
  .hero__eb-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #b0da2d;
    flex-shrink: 0;
    margin-top: 5px;
    animation: pulse 2s ease-in-out infinite;
  }
  .hero__early-bird div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hero__eb-label {
    font-family: "Bebas Neue", sans-serif;
    font-size: 12px;
    letter-spacing: 0.2em;
    color: #de1551;
  }
  .hero__eb-sub {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.48);
  }

  /* ============================================================
   HERO: BOLETAS PRÓXIMAMENTE
   ============================================================ */
  .hero__boletas-pronto {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    border: 1px solid rgba(176, 218, 45, 0.28);
    border-radius: 8px;
    background: rgba(176, 218, 45, 0.06);
    max-width: 540px;
  }
  .hero__bp-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #b0da2d;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(176, 218, 45, 0.6);
    animation: pulse 2s ease-in-out infinite;
  }
  .hero__boletas-pronto > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }
  .hero__bp-titulo {
    font-family: "Bebas Neue", sans-serif;
    font-size: 13px;
    letter-spacing: 0.22em;
    color: #b0da2d;
  }
  .hero__bp-sub {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 11px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.48);
  }
  .hero__bp-link {
    font-family: "Manrope", sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
    transition: color 0.2s;
    text-decoration: none;
  }
  .hero__bp-link:hover {
    color: #b0da2d;
  }

  /* ============================================================
   BOLETAS
   ============================================================ */
  .boletas {
    background: var(--color-morado);
    padding: 100px 48px;
    border-top: 1px solid var(--color-border-on-dark);
  }
  .boletas__head {
    text-align: center;
    margin-bottom: 56px;
  }
  .boletas__eyebrow {
    font-family: "Bebas Neue", sans-serif;
    font-size: 12px;
    letter-spacing: 0.26em;
    color: rgba(255, 255, 255, 0.28);
    margin-bottom: 12px;
  }
  .boletas__titulo {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(34px, 5vw, 56px);
    letter-spacing: -0.03em;
    line-height: 1;
    color: white;
    margin-bottom: 24px;
  }
  .boletas__titulo em {
    color: #b0da2d;
    font-style: italic;
  }
  .boletas__pronto-banner {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border: 1px solid rgba(176, 218, 45, 0.3);
    border-radius: 100px;
    background: rgba(176, 218, 45, 0.07);
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
  }
  .boletas__pronto-banner strong {
    color: #b0da2d;
  }
  .boletas__pronto-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #b0da2d;
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }
  .boletas__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 860px;
    margin: 0 auto 40px;
  }
  .boleta__card {
    border: 1px solid var(--color-border-on-dark);
    border-radius: 12px;
    padding: 36px 32px 28px;
    background: rgba(255, 255, 255, 0.03);
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
    overflow: hidden;
  }
  .boleta__card--dia3 {
    border-color: rgba(222, 21, 81, 0.35);
    background: rgba(222, 21, 81, 0.04);
  }
  /* Pills */
  .boleta__pills {
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
  }
  .boleta__pill {
    font-family: "Bebas Neue", sans-serif;
    font-size: 10px; letter-spacing: 0.2em;
    padding: 3px 9px; border-radius: 4px;
    color: rgba(255,255,255,0.5);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
  }
  .boleta__pill--mismo {
    color: #b0da2d;
    background: rgba(176,218,45,0.08);
    border-color: rgba(176,218,45,0.25);
  }
  .boleta__pill--cierre {
    color: #de1551;
    background: rgba(222,21,81,0.08);
    border-color: rgba(222,21,81,0.25);
  }
  /* Fechas */
  .boleta__fechas {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  }
  .boleta__fecha {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: clamp(26px, 4vw, 36px);
    letter-spacing: -0.03em; line-height: 1;
    color: white;
  }
  .boleta__fecha-sep {
    font-family: "Manrope", sans-serif;
    font-weight: 300; font-size: 22px;
    color: rgba(255,255,255,0.2);
  }
  .boleta__filas {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border-on-dark);
    border-bottom: 1px solid var(--color-border-on-dark);
  }
  .boleta__fila {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-border-on-dark);
  }
  .boleta__fila:last-child {
    border-bottom: none;
  }
  .boleta__tipo {
    font-family: "Montserrat Alternates", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .boleta__vip-badge {
    font-family: "Bebas Neue", sans-serif;
    font-size: 9px;
    letter-spacing: 0.18em;
    background: rgba(255, 215, 0, 0.15);
    color: #ffe700;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid rgba(255, 215, 0, 0.25);
  }
  .boleta__precio {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: white;
    letter-spacing: -0.02em;
  }
  .boleta__precio--vip {
    color: #ffe700;
  }
  .boleta__precio--gratis {
    font-family: "Bebas Neue", sans-serif;
    font-size: 15px;
    letter-spacing: 0.16em;
    color: #b0da2d;
  }
  .boleta__precio--pronto {
    font-family: "Bebas Neue", sans-serif;
    font-size: 13px;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.75);
  }
  .boleta__cta-wrap {
    margin-top: 4px;
  }
  .boleta__cta-pronto {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 0;
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 6px;
    cursor: not-allowed;
