<script>
  const lineup = document.getElementById("heroLineup");
  if (lineup) {
    const cards = Array.from(lineup.querySelectorAll(".hero__lineup-card"));
    const thumbs = Array.from(lineup.querySelectorAll(".hero__lineup-thumb"));
    const counter = document.getElementById("lineupCounter");
    const bar = document.getElementById("lineupBar");
    let current = 0;

    function pad(n: number) {
      return n < 10 ? "0" + n : String(n);
    }

    function resetBar() {
      if (!bar) return;
      bar.style.animation = "none";
      void (bar as HTMLElement).offsetWidth;
      bar.style.animation = "";
    }

    function show(idx: number) {
      cards[current].classList.remove("hero__lineup-card--active");
      thumbs[current].classList.remove("hero__lineup-thumb--active");
      current = ((idx % cards.length) + cards.length) % cards.length;
      cards[current].classList.add("hero__lineup-card--active");
      thumbs[current].classList.add("hero__lineup-thumb--active");
      if (counter) counter.textContent = `${pad(current + 1)} / ${pad(cards.length)}`;
      resetBar();
    }

    let timer = setInterval(() => show(current + 1), 3500);

    thumbs.forEach((thumb, i) => {
      thumb.addEventListener("click", (e) => {
        e.preventDefault();
        clearInterval(timer);
        show(i);
        timer = setInterval(() => show(current + 1), 3500);
      });
    });

    lineup.addEventListener("mouseenter", () => clearInterval(timer));
    lineup.addEventListener("mouseleave", () => {
      timer = setInterval(() => show(current + 1), 3500);
    });
  }
</script>
